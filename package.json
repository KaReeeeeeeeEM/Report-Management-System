{
  "name": "report-management-system",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop and web report management system for document storage, sharing, and review workflows.",
  "author": {
    "name": "Kwangu Zabrone",
    "email": "kwangu.zabrone@tie.go.tz"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "next dev --hostname 127.0.0.1 --port 3001",
    "dev:electron": "electron .",
    "dev:desktop": "concurrently -k \"pnpm dev:web\" \"wait-on http://127.0.0.1:3001/login && pnpm dev:electron\"",
    "build": "pnpm build:web",
    "build:web": "node scripts/build-web.mjs",
    "build:desktop": "node scripts/generate-electron-icons.mjs && pnpm build:web && node scripts/prepare-electron-bundle.mjs && electron-builder",
    "build:installer": "node scripts/build-installer.mjs",
    "build:installer:mac": "node scripts/build-installer.mjs mac",
    "build:installer:win": "node scripts/build-installer.mjs win",
    "build:installer:win:x64": "node scripts/build-installer.mjs win x64",
    "build:installer:win:arm64": "node scripts/build-installer.mjs win arm64",
    "build:installer:linux": "node scripts/build-installer.mjs linux",
    "build:installer:linux:x64": "node scripts/build-installer.mjs linux x64",
    "build:installer:linux:arm64": "node scripts/build-installer.mjs linux arm64",
    "open:desktop": "node scripts/open-desktop-app.mjs",
    "start": "pnpm start:web",
    "start:web": "next start --hostname 127.0.0.1 --port 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "intro.js": "^8.3.2",
    "jose": "^6.1.0",
    "lucide-react": "^0.511.0",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.17.2",
    "next": "^15.5.2",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "5.4.296",
    "react": "^19.1.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.1.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^39.8.8",
    "electron-builder": "^26.8.1",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.2",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.reportmanagementsystem.desktop",
    "productName": "Report Management System",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "electron/bundle/app/**/*",
      "electron/*.cjs"
    ],
    "extraResources": [
      {
        "from": "electron/icons",
        "to": "icons"
      }
    ],
    "icon": "electron/icons/logo.png",
    "mac": {
      "icon": "electron/icons/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "packageManager": "pnpm@10.28.0"
}
